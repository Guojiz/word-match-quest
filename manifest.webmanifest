{
  "name": "Word Snap",
  "short_name": "Word Snap",
  "description": "A fast vocabulary matching practice app.",
  "start_url": "./vocabulary-match.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#131f24",
  "theme_color": "#131f24",
  "orientation": "portrait",
  "icons": [
    {
      "src": "./icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ]
}
